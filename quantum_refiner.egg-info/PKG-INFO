## 💻 Usage Examples

### Python API Example

```python
from pathlib import Path
from quantum_refiner import (
    CryptoManager,
    KeyManagementService,
    SecureDatasetHandler,
)

# Initialize services
crypto = CryptoManager()
kms = KeyManagementService()

# Generate keys
kyber_kp = kms.generate_kyber_key()
dilithium_kp = kms.generate_dilithium_key()

# Create secure dataset handler
handler = SecureDatasetHandler(
    storage_dir=Path("./secure_datasets"),
    chunk_size_mb=10,
    crypto=crypto,
    kms=kms,
)

# Encrypt dataset
result = handler.encrypt_dataset(
    dataset_path=Path("data/training_data.bin"),
    dataset_name="my_dataset",
)

print(f"✅ Dataset encrypted: {result['dataset_id']}")
print(f"   Merkle Root: {result['merkle_root']}")
print(f"   Chunks: {result['total_chunks']}")

# Decrypt for training
handler.decrypt_dataset(
    dataset_name="my_dataset",
    kyber_key_id=kyber_kp.public_key.hex()[:16],
    dilithium_public_key=dilithium_kp.public_key,
    output_path=Path("data/decrypted.bin"),
)
```

### Secure Training with PyTorch

```python
from quantum_refiner.training import SecureTrainingPipeline

# Initialize pipeline
pipeline = SecureTrainingPipeline(
    dataset_dir=Path("secure_datasets/my_dataset"),
    kyber_key_id="my_kyber_key",
)

# Create secure data loader
loader = pipeline.create_data_loader(batch_size=32)

# Training loop with on-the-fly decryption
for epoch in range(3):
    for batch_data in loader.get_batch_iterator():
        # batch_data is decrypted in-memory, never persisted
        # Process batch with your model
        logits = model(batch_data)
        loss = criterion(logits, labels)
        
        # No plaintext written to disk!
```

### Custom Attack Simulation

```python
import os
from quantum_refiner.pqc_crypto import CryptoManager
from quantum_refiner.integrity import IntegrityVerifier

crypto = CryptoManager()
verifier = IntegrityVerifier(crypto)

# Scenario: Detect tampering
original_hashes = [crypto.compute_hash(b"chunk_1"), 
                   crypto.compute_hash(b"chunk_2")]

# Attacker modifies chunk 1
tampered_hashes = [os.urandom(32), original_hashes[1]]

# Detection
tampering = verifier.detect_tampering(original_hashes, tampered_hashes)
print(f"Chunk 0 tampered: {tampering[0]}")  # True
print(f"Chunk 1 tampered: {tampering[1]}")  # False
```

